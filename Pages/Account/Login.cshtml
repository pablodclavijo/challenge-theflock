@page
@model AdminPanel.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/output.css" />
</head>
<body class="bg-gradient-to-br from-[#667eea] to-[#764ba2] min-h-screen flex items-center justify-center font-sans">
    <div class="w-full max-w-[420px] p-4">
        <div class="bg-white rounded-2xl shadow-[0_10px_40px_rgba(0,0,0,0.2)] overflow-hidden">
            <div class="bg-gradient-to-br from-[#667eea] to-[#764ba2] text-white p-8 text-center">
                <i class="bi bi-shield-lock text-5xl mb-4 block"></i>
                <h1 class="text-2xl font-semibold mb-0">Admin Panel</h1>
                <p class="mb-0">Iniciar Sesión</p>
            </div>

            <div class="p-8">
                <form method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="bg-red-100 text-red-800 px-3 py-3 rounded-lg mb-4" role="alert"></div>
                    }

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control" placeholder="nombre@ejemplo.com" autocomplete="username">
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-red-600 text-sm"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.Password" class="form-control" placeholder="Contraseña" autocomplete="current-password">
                        <label asp-for="Input.Password">Contraseña</label>
                        <span asp-validation-for="Input.Password" class="text-red-600 text-sm"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="Input.RememberMe" class="form-check-input">
                        <label asp-for="Input.RememberMe" class="form-check-label">
                            Recordarme
                        </label>
                    </div>

                    <button type="submit" class="w-full px-4 py-3 text-base font-semibold bg-gradient-to-br from-[#667eea] to-[#764ba2] border-0 rounded-lg text-white transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-[0_5px_15px_rgba(102,126,234,0.4)]">
                        <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión
                    </button>
                </form>

                <div class="bg-gray-100 rounded-lg p-4 mt-6 text-sm">
                    <h6 class="text-sm font-semibold mb-2 text-gray-700"><i class="bi bi-info-circle"></i> Credenciales de Prueba</h6>
                    <p class="my-1 text-gray-600"><strong>Admin:</strong> admin@("@")admin.com / Admin123!</p>
                    <p class="my-1 text-gray-600"><strong>Vendedor:</strong> vendedor@("@")vendedor.com / Vendedor123!</p>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
