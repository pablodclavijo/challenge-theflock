@page
@using AdminPanel.Pages.Products
@model AdminPanel.Pages.Products.AdjustStockModel
@{
    ViewData["Title"] = "Ajustar Stock";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1>Ajustar Stock</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-page="./Index">Productos</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Ajustar Stock</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2>Ajustar Stock - @Model.Product.Name</h2>
            </div>
            <div class="admin-card-body">
                <div class="alert alert-info mb-4">
                    <i class="bi bi-info-circle"></i>
                    <strong>Stock Actual:</strong> 
                    @{
                        var stockClass = Model.Product.Stock == 0 ? "danger" : (Model.Product.Stock < 10 ? "warning" : "success");
                    }
                    <span class="badge bg-@stockClass fs-6">@Model.Product.Stock unidades</span>
                </div>

                <form method="post">
                    <input type="hidden" asp-for="Input.ProductId" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Input.AdjustmentType" class="form-label"></label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="Input.AdjustmentType" 
                                   id="adjustTypeAdd" value="@AdjustStockModel.AdjustmentType.Add" 
                                   checked="@(Model.Input?.AdjustmentType == AdjustStockModel.AdjustmentType.Add || Model.Input == null)" />
                            <label class="btn btn-outline-success" for="adjustTypeAdd">
                                <i class="bi bi-plus-circle"></i> Agregar
                            </label>

                            <input type="radio" class="btn-check" name="Input.AdjustmentType" 
                                   id="adjustTypeSubtract" value="@AdjustStockModel.AdjustmentType.Subtract"
                                   checked="@(Model.Input?.AdjustmentType == AdjustStockModel.AdjustmentType.Subtract)" />
                            <label class="btn btn-outline-danger" for="adjustTypeSubtract">
                                <i class="bi bi-dash-circle"></i> Restar
                            </label>

                            <input type="radio" class="btn-check" name="Input.AdjustmentType" 
                                   id="adjustTypeSet" value="@AdjustStockModel.AdjustmentType.Set"
                                   checked="@(Model.Input?.AdjustmentType == AdjustStockModel.AdjustmentType.Set)" />
                            <label class="btn btn-outline-primary" for="adjustTypeSet">
                                <i class="bi bi-arrow-repeat"></i> Establecer
                            </label>
                        </div>
                        <span asp-validation-for="Input.AdjustmentType" class="text-danger"></span>
                        <small class="form-text text-muted d-block mt-2">
                            <strong>Agregar:</strong> Suma la cantidad al stock actual. 
                            <strong>Restar:</strong> Resta la cantidad del stock actual. 
                            <strong>Establecer:</strong> Define el stock exacto.
                        </small>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.Quantity" class="form-label"></label>
                        <input asp-for="Input.Quantity" class="form-control form-control-lg" 
                               type="number" min="1" />
                        <span asp-validation-for="Input.Quantity" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.Reason" class="form-label"></label>
                        <textarea asp-for="Input.Reason" class="form-control" rows="3" 
                                  placeholder="Ej: Recepción de mercancía, Inventario, Devolución, etc."></textarea>
                        <span asp-validation-for="Input.Reason" class="text-danger"></span>
                        <small class="form-text text-muted">
                            Opcional: Ingrese el motivo del ajuste para llevar un mejor control
                        </small>
                    </div>

                    <div id="stockPreview" class="alert alert-secondary mb-4" style="display:none;">
                        <strong>Nuevo Stock:</strong> 
                        <span id="newStockValue" class="fs-5">0</span> unidades
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Confirmar Ajuste
                        </button>
                        <a asp-page="./Details" asp-route-id="@Model.Product.Id" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2>Información del Producto</h2>
            </div>
            <div class="admin-card-body">
                @if (!string.IsNullOrEmpty(Model.Product.ImageUrl))
                {
                    <img src="@Model.Product.ImageUrl" alt="@Model.Product.Name" 
                         class="img-fluid rounded border mb-3" 
                         style="width: 100%; max-height: 200px; object-fit: cover;" />
                }

                <h5>@Model.Product.Name</h5>
                <p class="text-muted">@Model.Product.Description</p>

                <div class="mb-2">
                    <strong>Categoría:</strong> 
                    <span class="badge bg-secondary">@Model.Product.Category.Name</span>
                </div>

                <div class="mb-2">
                    <strong>Precio:</strong> 
                    <span class="text-success">$@Model.Product.Price.ToString("N2")</span>
                </div>

                <div class="mb-2">
                    <strong>Estado:</strong> 
                    @if (Model.Product.IsActive)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactivo</span>
                    }
                </div>

                <hr />

                <a asp-page="./Details" asp-route-id="@Model.Product.Id" class="btn btn-outline-primary w-100">
                    <i class="bi bi-eye"></i> Ver Detalles
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        const currentStock = @Model.Product.Stock;
        const quantityInput = document.querySelector('input[name="Input.Quantity"]');
        const adjustmentTypeInputs = document.querySelectorAll('input[name="Input.AdjustmentType"]');
        const stockPreview = document.getElementById('stockPreview');
        const newStockValue = document.getElementById('newStockValue');

        function updateStockPreview() {
            const quantity = parseInt(quantityInput.value) || 0;
            const adjustmentType = document.querySelector('input[name="Input.AdjustmentType"]:checked')?.value;
            
            let newStock = currentStock;
            
            if (adjustmentType === '@AdjustStockModel.AdjustmentType.Add') {
                newStock = currentStock + quantity;
            } else if (adjustmentType === '@AdjustStockModel.AdjustmentType.Subtract') {
                newStock = Math.max(0, currentStock - quantity);
            } else if (adjustmentType === '@AdjustStockModel.AdjustmentType.Set') {
                newStock = quantity;
            }
            
            newStockValue.textContent = newStock;
            stockPreview.style.display = 'block';
            
            // Update alert style based on new stock
            stockPreview.className = 'alert mb-4';
            if (newStock === 0) {
                stockPreview.classList.add('alert-danger');
            } else if (newStock < 10) {
                stockPreview.classList.add('alert-warning');
            } else {
                stockPreview.classList.add('alert-success');
            }
        }

        quantityInput.addEventListener('input', updateStockPreview);
        adjustmentTypeInputs.forEach(input => {
            input.addEventListener('change', updateStockPreview);
        });

        // Initial preview
        updateStockPreview();
    </script>
}
