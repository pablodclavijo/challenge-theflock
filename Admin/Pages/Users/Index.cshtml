@page
@model AdminPanel.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Usuarios";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1>Usuarios y Vendedores</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Index">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Usuarios</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-page="./Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nuevo Usuario
            </a>
        </div>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <h2>Listado de Usuarios</h2>
    </div>
    <div class="admin-card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Email</th>
                        <th>Nombre Completo</th>
                        <th class="text-center">Rol</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Email Verificado</th>
                        <th>Fecha Registro</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users.Any())
                    {
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>
                                    <strong>@user.Email</strong>
                                </td>
                                <td>@user.FullName</td>
                                <td class="text-center">
                                    @if (user.Role == AdminPanel.Constants.Roles.Admin)
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-shield-check"></i> Admin
                                        </span>
                                    }
                                    else if (user.Role == AdminPanel.Constants.Roles.Vendedor)
                                    {
                                        <span class="badge bg-info">
                                            <i class="bi bi-person-badge"></i> Vendedor
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@user.Role</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-x-circle"></i> Inactivo
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (user.EmailConfirmed)
                                    {
                                        <i class="bi bi-check-circle-fill text-success"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-x-circle-fill text-danger"></i>
                                    }
                                </td>
                                <td>
                                    <small>@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-page="./Edit" asp-route-id="@user.Id" 
                                           class="btn btn-outline-secondary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (user.Role != AdminPanel.Constants.Roles.Admin)
                                        {
                                            <a asp-page="./ToggleStatus" asp-route-id="@user.Id" 
                                               class="btn btn-outline-@(user.IsActive ? "warning" : "success")" 
                                               title="@(user.IsActive ? "Desactivar" : "Activar")">
                                                <i class="bi bi-@(user.IsActive ? "lock" : "unlock")"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-outline-secondary" disabled title="No se puede desactivar a otro administrador">
                                                <i class="bi bi-shield-lock"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-inbox"></i>
                                <p class="mb-0 mt-2">No hay usuarios registrados</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <h2><i class="bi bi-info-circle"></i> Información</h2>
    </div>
    <div class="admin-card-body">
        <ul class="mb-0">
            <li><strong>Admin:</strong> Acceso completo al sistema, puede gestionar productos, pedidos, categorías y usuarios.</li>
            <li><strong>Vendedor:</strong> Puede gestionar productos y pedidos únicamente.</li>
            <li>Al desactivar un usuario, este no podrá iniciar sesión en el sistema.</li>
        </ul>
    </div>
</div>
