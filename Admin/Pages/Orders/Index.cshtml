@page
@using AdminPanel.Enums
@model AdminPanel.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Pedidos";
    Layout = "_AdminLayout";
}

<!-- Toast container for live order notifications -->
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1100">
    <div id="newOrderToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body fw-semibold">
                <i class="bi bi-bag-check-fill me-2"></i>
                <span id="toastOrderBody">Nuevo pedido recibido</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1>Pedidos</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Index">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Pedidos</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <h2>Listado de Pedidos</h2>
    </div>
    <div class="admin-card-body">
        <!-- Filtros -->
        <form method="get" class="mb-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Estado</label>
                    <select name="statusFilter" class="form-select" onchange="this.form.submit()">
                        <option value="">Todos los estados</option>
                        <option value="@OrderStatus.Pending" selected="@(Model.CurrentStatusFilter == OrderStatus.Pending.ToString())">Pendiente</option>
                        <option value="@OrderStatus.Confirmed" selected="@(Model.CurrentStatusFilter == OrderStatus.Confirmed.ToString())">Confirmado</option>
                        <option value="@OrderStatus.Shipped" selected="@(Model.CurrentStatusFilter == OrderStatus.Shipped.ToString())">Enviado</option>
                        <option value="@OrderStatus.Delivered" selected="@(Model.CurrentStatusFilter == OrderStatus.Delivered.ToString())">Entregado</option>
                        <option value="@OrderStatus.Paid" selected="@(Model.CurrentStatusFilter == OrderStatus.Paid.ToString())">Pagado</option>
                        <option value="@OrderStatus.PaymentFailed" selected="@(Model.CurrentStatusFilter == OrderStatus.PaymentFailed.ToString())">Pago Fallido</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Desde</label>
                    <input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" 
                           class="form-control" onchange="this.form.submit()">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Hasta</label>
                    <input type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" 
                           class="form-control" onchange="this.form.submit()">
                </div>
                @if (!string.IsNullOrEmpty(Model.CurrentStatusFilter) || Model.DateFrom.HasValue || Model.DateTo.HasValue)
                {
                    <div class="col-auto d-flex align-items-end">
                        <a asp-page="./Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Limpiar filtros
                        </a>
                    </div>
                }
            </div>
        </form>

        @{
            string GetStatusBadge(OrderStatus status)
            {
                string badgeClass = status switch
                {
                    OrderStatus.Pending => "warning",
                    OrderStatus.Confirmed => "info",
                    OrderStatus.Shipped => "primary",
                    OrderStatus.Delivered => "success",
                    OrderStatus.Paid => "success",
                    OrderStatus.PaymentFailed => "danger",
                    _ => "secondary"
                };
                string statusText = status switch
                {
                    OrderStatus.Pending => "Pendiente",
                    OrderStatus.Confirmed => "Confirmado",
                    OrderStatus.Shipped => "Enviado",
                    OrderStatus.Delivered => "Entregado",
                    OrderStatus.Paid => "Pagado",
                    OrderStatus.PaymentFailed => "Pago Fallido",
                    _ => status.ToString()
                };
                return $"<span class='badge bg-{badgeClass}'>{statusText}</span>";
            }

            ViewData["Columns"] = new List<(string Header, Func<dynamic, object> Cell, string CssClass)>
            {
                ("# Orden", (dynamic o) => $"<strong>#{o.Id}</strong>", ""),
                
                ("Cliente", (dynamic o) => $"<div><strong>{o.User?.FullName ?? "N/A"}</strong><br><small class='text-muted'>{o.User?.Email ?? ""}</small></div>", ""),
                
                ("Items", (dynamic o) => $"<span class='badge bg-secondary'>{o.Items.Count} item(s)</span>", "text-center"),
                
                ("Total", (dynamic o) => $"<strong>${o.Total:N2}</strong>", "text-end"),
                
                ("Estado", (dynamic o) => (object)GetStatusBadge((OrderStatus)o.Status), "text-center"),
                
                ("Fecha", (dynamic o) => $"<small>{o.CreatedAt:dd/MM/yyyy}<br>{o.CreatedAt:HH:mm}</small>", ""),
                
                ("Acciones", (dynamic o) => $@"
                    <div class='btn-group btn-group-sm' role='group'>
                        <button type='button' class='btn btn-outline-primary' title='Ver Detalles' 
                                onclick='showOrderDetails({o.Id})'>
                            <i class='bi bi-eye'></i>
                        </button>
                    </div>", 
                    "text-end")
            };

            ViewData["BaseUrl"] = "/Orders/Index";
            ViewData["CurrentQuery"] = new Dictionary<string, string>
            {
                ["statusFilter"] = Model.CurrentStatusFilter,
                ["dateFrom"] = Model.DateFrom?.ToString("yyyy-MM-dd") ?? "",
                ["dateTo"] = Model.DateTo?.ToString("yyyy-MM-dd") ?? ""
            };
        }

        <partial name="_DataTable" model="Model.Orders" />
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-3 mt-3">
    <div class="col-6 col-md-3">
        <div class="admin-card">
            <div class="admin-card-body text-center">
                <div class="text-muted small">Pendientes</div>
                <div class="fs-4 fw-bold text-warning">
                    @Model.Orders.Items.Count(o => o.Status == OrderStatus.Pending)
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="admin-card">
            <div class="admin-card-body text-center">
                <div class="text-muted small">Confirmados</div>
                <div class="fs-4 fw-bold text-info">
                    @Model.Orders.Items.Count(o => o.Status == OrderStatus.Confirmed)
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="admin-card">
            <div class="admin-card-body text-center">
                <div class="text-muted small">Enviados</div>
                <div class="fs-4 fw-bold text-primary">
                    @Model.Orders.Items.Count(o => o.Status == OrderStatus.Shipped)
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="admin-card">
            <div class="admin-card-body text-center">
                <div class="text-muted small">Entregados</div>
                <div class="fs-4 fw-bold text-success">
                    @Model.Orders.Items.Count(o => o.Status == OrderStatus.Delivered)
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Order Details Modal -->
<div class="modal fade" id="orderDetailsModal" tabindex="-1" aria-labelledby="orderDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="orderDetailsModalLabel">Detalles del Pedido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="orderDetailsContent">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Change Status Confirmation Modal -->
<div class="modal fade" id="changeStatusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-arrow-repeat"></i> Cambiar Estado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">¿Está seguro de que desea cambiar el estado del pedido?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cancelar
                </button>
                <button type="button" class="btn btn-primary" id="confirmChangeStatusBtn">
                    <i class="bi bi-check-circle"></i> Confirmar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
        /*  Order detail modal  */
        function showOrderDetails(orderId) {
            const modal   = new bootstrap.Modal(document.getElementById('orderDetailsModal'));
            const content = document.getElementById('orderDetailsContent');
            content.innerHTML = `
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                </div>`;
            modal.show();
            fetch(`/Orders/Details?id=${orderId}&handler=OrderDetails`)
                .then(r => r.text())
                .then(html => { content.innerHTML = html; })
                .catch(() => {
                    content.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> Error al cargar los detalles del pedido.</div>';
                });
        }

        /*  Status change  */
        let pendingStatusOrderId = null;
        let pendingStatusNewStatus = null;

        function changeOrderStatus(orderId, newStatus) {
            pendingStatusOrderId = orderId;
            pendingStatusNewStatus = newStatus;
            const modal = new bootstrap.Modal(document.getElementById('changeStatusModal'));
            modal.show();
        }

        document.getElementById('confirmChangeStatusBtn').addEventListener('click', function () {
            const modalEl = document.getElementById('changeStatusModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) modal.hide();
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            fetch('/Orders/ChangeStatus?handler=ChangeStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({ orderId: pendingStatusOrderId, newStatus: pendingStatusNewStatus })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) { location.reload(); }
                else { alert('Error: ' + (data.message || 'No se pudo cambiar el estado')); }
            })
            .catch(() => alert('Error al cambiar el estado del pedido'));
        });

        /*  SignalR live updates  */
        function showNewOrderToast(data) {
            const body = document.getElementById('toastOrderBody');
            if (body) {
                const art = data.itemCount === 1 ? 'articulo' : 'articulos';
                body.textContent = 'Nuevo pedido #' + data.orderId + ' - $' + Number(data.total).toFixed(2) + ' (' + data.itemCount + ' ' + art + ')';
            }
            const toastEl = document.getElementById('newOrderToast');
            if (toastEl) new bootstrap.Toast(toastEl, { delay: 6000 }).show();
            setTimeout(function() { location.reload(); }, 4000);
        }

        (function startSignalR() {
            if (typeof signalR === 'undefined') {
                setTimeout(startSignalR, 1000);
                return;
            }
            var connection = new signalR.HubConnectionBuilder()
                .withUrl('/orderHub')
                .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
                .configureLogging(signalR.LogLevel.Warning)
                .build();

            connection.on('NewOrderReceived', showNewOrderToast);

            connection.start()
                .then(function() { console.log('[SignalR] Connected to /orderHub'); })
                .catch(function(err) {
                    console.error('[SignalR] Failed to connect:', err);
                    setTimeout(startSignalR, 10000);
                });
        })();

        /*  Polling fallback every 30 s  */
        setInterval(function() { location.reload(); }, 30000);
    </script>
}