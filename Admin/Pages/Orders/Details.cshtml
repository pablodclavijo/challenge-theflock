@page
@using AdminPanel.Enums
@model AdminPanel.Pages.Orders.DetailsModel
@{
    ViewData["Title"] = $"Pedido #{Model.Order.Id}";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1>Pedido #@Model.Order.Id</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-page="./Index">Pedidos</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Pedido #@Model.Order.Id</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-page="./Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-3">
    <!-- Order Info -->
    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2>Información del Pedido</h2>
            </div>
            <div class="admin-card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <p><strong>Estado:</strong></p>
                        @{
                            var statusBadge = Model.Order.Status switch
                            {
                                OrderStatus.Pending => "warning",
                                OrderStatus.Confirmed => "info",
                                OrderStatus.Shipped => "primary",
                                OrderStatus.Delivered => "success",
                                OrderStatus.Paid => "success",
                                OrderStatus.PaymentFailed => "danger",
                                _ => "secondary"
                            };
                            var statusText = Model.Order.Status switch
                            {
                                OrderStatus.Pending => "Pendiente",
                                OrderStatus.Confirmed => "Confirmado",
                                OrderStatus.Shipped => "Enviado",
                                OrderStatus.Delivered => "Entregado",
                                OrderStatus.Paid => "Pagado",
                                OrderStatus.PaymentFailed => "Pago Fallido",
                                _ => Model.Order.Status.ToString()
                            };
                        }
                        <span class="badge bg-@statusBadge fs-6">@statusText</span>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Fecha de creación:</strong> @Model.Order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        <p><strong>Última actualización:</strong> @Model.Order.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>

                <hr />

                <h4 class="mb-3">Productos</h4>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio Unit.</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Order.Items)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.ProductNameSnapshot</strong>
                                        @if (item.Product != null)
                                        {
                                            <br />
                                            <small class="text-muted">
                                                Stock actual: <span class="badge bg-@(item.Product.Stock > 0 ? "success" : "danger")">@item.Product.Stock</span>
                                            </small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary">@item.Quantity</span>
                                    </td>
                                    <td class="text-end">$@item.UnitPriceSnapshot.ToString("N2")</td>
                                    <td class="text-end"><strong>$@item.LineTotal.ToString("N2")</strong></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end"><strong>Subtotal:</strong></td>
                                <td class="text-end"><strong>$@Model.Order.Subtotal.ToString("N2")</strong></td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-end"><strong>Impuestos:</strong></td>
                                <td class="text-end"><strong>$@Model.Order.Tax.ToString("N2")</strong></td>
                            </tr>
                            <tr class="table-active">
                                <td colspan="3" class="text-end"><strong>TOTAL:</strong></td>
                                <td class="text-end"><strong class="fs-5">$@Model.Order.Total.ToString("N2")</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Customer & Status Actions -->
    <div class="col-lg-4">
        <!-- Customer Info -->
        <div class="admin-card mb-3">
            <div class="admin-card-header">
                <h2>Datos del Comprador</h2>
            </div>
            <div class="admin-card-body">
                <p><strong>Nombre:</strong><br />@Model.Order.User.FullName</p>
                <p><strong>Email:</strong><br />@Model.Order.User.Email</p>
                <p><strong>Dirección de envío:</strong><br />@Model.Order.ShippingAddress</p>
            </div>
        </div>

        <!-- Status Change -->
        <div class="admin-card">
            <div class="admin-card-header">
                <h2>Cambiar Estado</h2>
            </div>
            <div class="admin-card-body">
                @{
                    var canPay = Model.Order.Status == OrderStatus.Pending;
                    var canMarkPaymentFailed = Model.Order.Status == OrderStatus.Pending;
                    var canRetryPayment = Model.Order.Status == OrderStatus.PaymentFailed;
                    var canConfirm = Model.Order.Status == OrderStatus.Paid;
                    var canShip = Model.Order.Status == OrderStatus.Confirmed;
                    var canDeliver = Model.Order.Status == OrderStatus.Shipped;
                }

                @if (canPay)
                {
                    <form method="post" asp-page-handler="ChangeStatus" class="mb-2">
                        <input type="hidden" name="orderId" value="@Model.Order.Id" />
                        <input type="hidden" name="newStatus" value="@((int)OrderStatus.Paid)" />
                        <button type="button" class="btn btn-success w-100" onclick="confirmStatusChange(this.closest('form'), 'Marcar como Pagado')">
                            <i class="bi bi-cash-coin"></i> Marcar como Pagado
                        </button>
                    </form>
                    <form method="post" asp-page-handler="ChangeStatus" class="mb-2">
                        <input type="hidden" name="orderId" value="@Model.Order.Id" />
                        <input type="hidden" name="newStatus" value="@((int)OrderStatus.PaymentFailed)" />
                        <button type="button" class="btn btn-danger w-100" onclick="confirmStatusChange(this.closest('form'), 'Marcar Pago Fallido')">
                            <i class="bi bi-x-circle"></i> Marcar Pago Fallido
                        </button>
                    </form>
                }

                @if (canRetryPayment)
                {
                    <form method="post" asp-page-handler="ChangeStatus" class="mb-2">
                        <input type="hidden" name="orderId" value="@Model.Order.Id" />
                        <input type="hidden" name="newStatus" value="@((int)OrderStatus.Paid)" />
                        <button type="button" class="btn btn-success w-100" onclick="confirmStatusChange(this.closest('form'), 'Reintentar Pago')">
                            <i class="bi bi-arrow-repeat"></i> Reintentar Pago
                        </button>
                    </form>
                }

                @if (canConfirm)
                {
                    <form method="post" asp-page-handler="ChangeStatus" class="mb-2">
                        <input type="hidden" name="orderId" value="@Model.Order.Id" />
                        <input type="hidden" name="newStatus" value="@((int)OrderStatus.Confirmed)" />
                        <button type="button" class="btn btn-info w-100" onclick="confirmStatusChange(this.closest('form'), 'Confirmar Pedido')">
                            <i class="bi bi-check-circle"></i> Confirmar Pedido
                        </button>
                        <small class="text-muted d-block mt-1">Se descontará el stock automáticamente</small>
                    </form>
                }

                @if (canShip)
                {
                    <form method="post" asp-page-handler="ChangeStatus" class="mb-2">
                        <input type="hidden" name="orderId" value="@Model.Order.Id" />
                        <input type="hidden" name="newStatus" value="@((int)OrderStatus.Shipped)" />
                        <button type="button" class="btn btn-primary w-100" onclick="confirmStatusChange(this.closest('form'), 'Marcar como Enviado')">
                            <i class="bi bi-box-seam"></i> Marcar como Enviado
                        </button>
                    </form>
                }

                @if (canDeliver)
                {
                    <form method="post" asp-page-handler="ChangeStatus" class="mb-2">
                        <input type="hidden" name="orderId" value="@Model.Order.Id" />
                        <input type="hidden" name="newStatus" value="@((int)OrderStatus.Delivered)" />
                        <button type="button" class="btn btn-success w-100" onclick="confirmStatusChange(this.closest('form'), 'Marcar como Entregado')">
                            <i class="bi bi-truck"></i> Marcar como Entregado
                        </button>
                    </form>
                }

                @if (!canPay && !canRetryPayment && !canConfirm && !canShip && !canDeliver)
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle"></i> El pedido ya está en su estado final.
                    </div>
                }

                <hr />

                <div class="small text-muted">
                    <p class="mb-1"><strong>Flujo de estados:</strong></p>
                    <p class="mb-0">
                        Pendiente &rarr; Pagado / Pago Fallido &rarr; Confirmado &rarr; Enviado &rarr; Entregado
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Change Status Confirmation Modal -->
<div class="modal fade" id="changeStatusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-arrow-repeat"></i> Confirmar cambio de estado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>¿Está seguro de que desea <strong id="changeStatusActionText"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cancelar
                </button>
                <button type="button" class="btn btn-primary" id="confirmChangeStatusBtn">
                    <i class="bi bi-check-circle"></i> Confirmar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let pendingStatusForm = null;

        function confirmStatusChange(form, actionText) {
            pendingStatusForm = form;
            document.getElementById('changeStatusActionText').textContent = actionText;
            const modal = new bootstrap.Modal(document.getElementById('changeStatusModal'));
            modal.show();
        }

        document.getElementById('confirmChangeStatusBtn').addEventListener('click', function () {
            const modalEl = document.getElementById('changeStatusModal');
            const modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) modal.hide();
            if (pendingStatusForm) pendingStatusForm.submit();
        });
    </script>
}
