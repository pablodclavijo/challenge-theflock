<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AdminPanel.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <!-- Mobile Header -->
    <header class="mobile-header">
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle Menu">
            <i class="bi bi-list"></i>
        </button>
        <span class="mobile-title">Admin Panel</span>
        <div class="mobile-user">
            <i class="bi bi-person-circle"></i>
        </div>
    </header>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h4>Admin Panel</h4>
            <button class="sidebar-close" id="sidebarClose" aria-label="Close Menu">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <!-- User Info -->
        <div class="sidebar-user-info">
            <div class="d-flex align-items-center px-3 py-2 mb-2" style="background: rgba(255,255,255,0.05); border-radius: 8px; margin: 0 1rem;">
                <i class="bi bi-person-circle fs-3 me-2"></i>
                <div class="flex-grow-1" style="min-width: 0;">
                    <div class="fw-semibold text-white small text-truncate">@User.Identity?.Name</div>
                    @if (User.IsInRole(AdminPanel.Constants.Roles.Admin))
                    {
                        <div class="badge bg-danger small">Administrador</div>
                    }
                    else if (User.IsInRole(AdminPanel.Constants.Roles.Vendedor))
                    {
                        <div class="badge bg-info small">Vendedor</div>
                    }
                </div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <ul>
                <li>
                    <a asp-page="/Index" class="sidebar-link">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                
                <!-- Sección de Vendedor -->
                <li class="sidebar-section-title">Gestión</li>
                
                <li>
                    <a asp-page="/Products/Index" class="sidebar-link">
                        <i class="bi bi-box-seam"></i>
                        <span>Productos</span>
                    </a>
                </li>
                <li>
                    <a asp-page="/Orders/Index" class="sidebar-link">
                        <i class="bi bi-cart"></i>
                        <span>Pedidos</span>
                    </a>
                </li>

                <!-- Sección solo Admin -->
                @if (User.IsInRole(AdminPanel.Constants.Roles.Admin))
                {
                    <li class="sidebar-divider"></li>
                    <li class="sidebar-section-title">Administración</li>
                    
                    <li>
                        <a asp-page="/Categories/Index" class="sidebar-link">
                            <i class="bi bi-tags"></i>
                            <span>Categorías</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/Users/Index" class="sidebar-link">
                            <i class="bi bi-people"></i>
                            <span>Usuarios/Vendedores</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/Reports/Index" class="sidebar-link">
                            <i class="bi bi-graph-up"></i>
                            <span>Reportes</span>
                        </a>
                    </li>
                }

                <li class="sidebar-divider"></li>
                
                <li>
                    <form method="post" asp-page="/Account/Logout" class="m-0">
                        <button type="submit" class="sidebar-link w-100 border-0 text-start" style="background: transparent;">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Cerrar Sesión</span>
                        </button>
                    </form>
                </li>
            </ul>
        </nav>
    </aside>

    <!-- Overlay for mobile -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Main Content -->
    <main class="main-content">
        <div class="content-wrapper">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()
        </div>

        <footer class="content-footer">
            <div class="footer-content">
                &copy; @DateTime.Now.Year - Admin Panel E-commerce
            </div>
        </footer>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin-layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
