@page
@model AdminPanel.Pages.Reports.IndexModel
@{
    ViewData["Title"] = "Reportes y Métricas";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1><i class="bi bi-graph-up"></i> Reportes y Métricas</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Reportes</li>
        </ol>
    </nav>
</div>

<!-- Ventas por Período -->
<div class="admin-card mb-4">
    <div class="admin-card-header">
        <h2><i class="bi bi-currency-dollar"></i> Ventas por Período</h2>
    </div>
    <div class="admin-card-body">
        <div class="row g-3">
            <div class="col-sm-6 col-lg-3">
                <div class="text-center p-3 bg-light rounded">
                    <div class="text-muted small mb-2">Hoy</div>
                    <div class="fs-3 fw-bold text-primary">$@Model.TodaySales.ToString("N2")</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="text-center p-3 bg-light rounded">
                    <div class="text-muted small mb-2">Última Semana</div>
                    <div class="fs-3 fw-bold text-info">$@Model.WeekSales.ToString("N2")</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="text-center p-3 bg-light rounded">
                    <div class="text-muted small mb-2">Último Mes</div>
                    <div class="fs-3 fw-bold text-success">$@Model.MonthSales.ToString("N2")</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="text-center p-3 bg-light rounded">
                    <div class="text-muted small mb-2">Total</div>
                    <div class="fs-3 fw-bold text-dark">$@Model.TotalSales.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Órdenes por Estado -->
<div class="admin-card mb-4">
    <div class="admin-card-header">
        <h2><i class="bi bi-cart"></i> Órdenes por Estado</h2>
    </div>
    <div class="admin-card-body">
        <div class="row g-3">
            <div class="col-6 col-md-3">
                <div class="text-center p-3 border rounded">
                    <div class="badge bg-warning mb-2">Pendiente</div>
                    <div class="fs-4 fw-bold">@Model.PendingOrders</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-center p-3 border rounded">
                    <div class="badge bg-info mb-2">Confirmado</div>
                    <div class="fs-4 fw-bold">@Model.ConfirmedOrders</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-center p-3 border rounded">
                    <div class="badge bg-primary mb-2">Enviado</div>
                    <div class="fs-4 fw-bold">@Model.ShippedOrders</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-center p-3 border rounded">
                    <div class="badge bg-success mb-2">Entregado</div>
                    <div class="fs-4 fw-bold">@Model.DeliveredOrders</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Productos Más Vendidos -->
    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2><i class="bi bi-trophy"></i> Top 10 Productos Más Vendidos</h2>
            </div>
            <div class="admin-card-body">
                @if (Model.TopProducts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Producto</th>
                                    <th class="text-center">Cantidad Vendida</th>
                                    <th class="text-end">Ingresos Generados</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.TopProducts.Count; i++)
                                {
                                    var product = Model.TopProducts[i];
                                    <tr>
                                        <td>
                                            @if (i == 0)
                                            {
                                                <i class="bi bi-trophy-fill text-warning fs-5"></i>
                                            }
                                            else if (i == 1)
                                            {
                                                <i class="bi bi-trophy-fill text-secondary fs-5"></i>
                                            }
                                            else if (i == 2)
                                            {
                                                <i class="bi bi-trophy-fill" style="color: #CD7F32;"></i>
                                            }
                                            else
                                            {
                                                <span>@(i + 1)</span>
                                            }
                                        </td>
                                        <td><strong>@product.ProductName</strong></td>
                                        <td class="text-center">
                                            <span class="badge bg-primary">@product.QuantitySold unidades</span>
                                        </td>
                                        <td class="text-end">
                                            <strong>$@product.TotalRevenue.ToString("N2")</strong>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-1"></i>
                        <p class="mb-0 mt-2">No hay datos de ventas aún</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Resumen General -->
    <div class="col-lg-4">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2><i class="bi bi-clipboard-data"></i> Resumen General</h2>
            </div>
            <div class="admin-card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span><i class="bi bi-cart-check text-success"></i> Órdenes Totales</span>
                        <strong class="fs-5">@Model.TotalOrders</strong>
                    </div>
                    <hr class="my-2">
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span><i class="bi bi-box-seam text-primary"></i> Productos</span>
                        <strong class="fs-5">@Model.TotalProducts</strong>
                    </div>
                    <hr class="my-2">
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span><i class="bi bi-tags text-info"></i> Categorías</span>
                        <strong class="fs-5">@Model.TotalCategories</strong>
                    </div>
                    <hr class="my-2">
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span><i class="bi bi-people text-secondary"></i> Usuarios</span>
                        <strong class="fs-5">@Model.TotalUsers</strong>
                    </div>
                    <hr class="my-2">
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span><i class="bi bi-exclamation-triangle text-warning"></i> Stock Bajo</span>
                        <strong class="fs-5 text-warning">@Model.LowStockProducts</strong>
                    </div>
                </div>

                @if (Model.LowStockProducts > 0)
                {
                    <a asp-page="/Products/Index" asp-route-sortOrder="stock" class="btn btn-warning w-100 mt-3">
                        <i class="bi bi-exclamation-circle"></i> Ver Productos
                    </a>
                }
            </div>
        </div>
    </div>
</div>
