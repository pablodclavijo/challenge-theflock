@page
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@model AdminPanel.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categorías";
    Layout = "_AdminLayout";
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
}

@* Anti-forgery token for AJAX requests *@
<input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1>Categorías</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Index">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Categorías</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-page="./Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nueva Categoría
            </a>
        </div>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <h2>Listado de Categorías</h2>
    </div>
    <div class="admin-card-body">
        <!-- Filtros y búsqueda -->
        <form method="get" class="mb-4">
            <div class="row g-3">
                <div class="col-md-6 col-lg-4">
                    <div class="input-group">
                        <input type="text" 
                               name="searchString" 
                               value="@Model.CurrentFilter" 
                               class="form-control" 
                               placeholder="Buscar por nombre...">
                        <button type="submit" class="btn btn-outline-secondary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <select name="isActive" class="form-select" onchange="this.form.submit()">
                        <option value="">Todos los estados</option>
                        <option value="true" selected="@(Model.CurrentStatus == true)">Activas</option>
                        <option value="false" selected="@(Model.CurrentStatus == false)">Inactivas</option>
                    </select>
                </div>
                <div class="col-md-6 col-lg-3">
                    <select name="sortOrder" class="form-select" onchange="this.form.submit()">
                        <option value="">Ordenar por: Nombre (A-Z)</option>
                        <option value="name_desc" selected="@(Model.CurrentSort == "name_desc")">Nombre (Z-A)</option>
                        <option value="date" selected="@(Model.CurrentSort == "date")">Fecha (Antigua a Reciente)</option>
                        <option value="date_desc" selected="@(Model.CurrentSort == "date_desc")">Fecha (Reciente a Antigua)</option>
                        <option value="products" selected="@(Model.CurrentSort == "products")">Productos (Menos a Más)</option>
                        <option value="products_desc" selected="@(Model.CurrentSort == "products_desc")">Productos (Más a Menos)</option>
                    </select>
                </div>
                @if (!string.IsNullOrEmpty(Model.CurrentFilter) || !string.IsNullOrEmpty(Model.CurrentSort) || Model.CurrentStatus.HasValue)
                {
                    <div class="col-auto">
                        <a asp-page="./Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Limpiar
                        </a>
                    </div>
                }
            </div>
        </form>

        <!-- Tabla de datos -->
        @{
            ViewData["Columns"] = new List<(string Header, Func<dynamic, object> Cell, string CssClass)>
            {
                ("Nombre", (dynamic c) => $"<div><strong>{c.Name}</strong></div>", ""),
                
                ("Productos", (dynamic c) => {
                    var count = c.ProductCount;
                    var badgeClass = count == 0 ? "secondary" : (count < 5 ? "info" : "primary");
                    return $"<span class='badge bg-{badgeClass}'><i class='bi bi-box-seam'></i> {count} producto(s)</span>";
                }, "text-center"),
                
                ("Estado", (dynamic c) => c.IsActive 
                    ? "<span class='badge bg-success'><i class='bi bi-check-circle'></i> Activa</span>"
                    : "<span class='badge bg-danger'><i class='bi bi-x-circle'></i> Inactiva</span>", 
                    "text-center"),
                
                ("Fecha de Creación", (dynamic c) => $"<small>{c.CreatedAt:dd/MM/yyyy}<br>{c.CreatedAt:HH:mm}</small>", ""),
                
                ("Acciones", (dynamic c) => {
                    var hasProducts = c.ProductCount > 0;
                    var deleteBtn = hasProducts 
                        ? $"<button type='button' class='btn btn-outline-secondary' disabled title='No se puede eliminar (tiene productos)'><i class='bi bi-trash'></i></button>"
                        : $"<a asp-page='./Delete' asp-route-id='{c.Id}' class='btn btn-outline-danger' title='Eliminar' onclick='return confirm(\"żEstá seguro de que desea eliminar esta categoría?\");'><i class='bi bi-trash'></i></a>";
                    
                    return $@"
                    <div class='btn-group btn-group-sm' role='group'>
                        <a asp-page='./Edit' asp-route-id='{c.Id}' class='btn btn-outline-secondary' title='Editar'>
                            <i class='bi bi-pencil'></i>
                        </a>
                        {deleteBtn}
                    </div>";
                }, "text-end")
            };

            ViewData["BaseUrl"] = "/Categories/Index";
            ViewData["CurrentQuery"] = new Dictionary<string, string>
            {
                ["searchString"] = Model.CurrentFilter ?? "",
                ["sortOrder"] = Model.CurrentSort ?? "",
                ["isActive"] = Model.CurrentStatus?.ToString() ?? ""
            };
        }

        <partial name="_DataTable" model="Model.Categories" />
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-3 mt-3">
    <div class="col-6 col-md-3">
        <div class="admin-card">
            <div class="admin-card-body text-center">
                <div class="text-muted small">Total Categorías</div>
                <div class="fs-4 fw-bold text-primary">
                    @Model.Categories.TotalCount
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="admin-card">
            <div class="admin-card-body text-center">
                <div class="text-muted small">Activas</div>
                <div class="fs-4 fw-bold text-success">
                    @Model.Categories.Items.Count(c => c.IsActive)
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="admin-card">
            <div class="admin-card-body text-center">
                <div class="text-muted small">Inactivas</div>
                <div class="fs-4 fw-bold text-danger">
                    @Model.Categories.Items.Count(c => !c.IsActive)
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="admin-card">
            <div class="admin-card-body text-center">
                <div class="text-muted small">Total Productos</div>
                <div class="fs-4 fw-bold text-info">
                    @Model.Categories.Items.Sum(c => c.ProductCount)
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Show success message from TempData
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-success alert-dismissible fade show';
                alertDiv.innerHTML = '<i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
                document.querySelector('.admin-card').insertAdjacentElement('beforebegin', alertDiv);
                
                setTimeout(() => {
                    alertDiv.classList.remove('show');
                }, 5000);
                </text>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-danger alert-dismissible fade show';
                alertDiv.innerHTML = '<i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
                document.querySelector('.admin-card').insertAdjacentElement('beforebegin', alertDiv);
                
                setTimeout(() => {
                    alertDiv.classList.remove('show');
                }, 5000);
                </text>
            }
        });
    </script>
}
