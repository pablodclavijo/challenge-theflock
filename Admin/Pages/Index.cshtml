@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h1>Dashboard</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
        </ol>
    </nav>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="admin-card">
            <div class="admin-card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-primary bg-opacity-10 text-primary rounded p-3">
                            <i class="bi bi-box-seam fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <div class="text-muted small">Productos</div>
                        <div class="fs-4 fw-bold">@Model.TotalProducts</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="admin-card">
            <div class="admin-card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-success bg-opacity-10 text-success rounded p-3">
                            <i class="bi bi-cart fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <div class="text-muted small">Órdenes Totales</div>
                        <div class="fs-4 fw-bold">@Model.TotalOrders</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="admin-card">
            <div class="admin-card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-info bg-opacity-10 text-info rounded p-3">
                            <i class="bi bi-currency-dollar fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <div class="text-muted small">Ingresos</div>
                        <div class="fs-4 fw-bold">${Model.TotalRevenue:N2}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="admin-card">
            <div class="admin-card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-warning bg-opacity-10 text-warning rounded p-3">
                            <i class="bi bi-exclamation-triangle fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <div class="text-muted small">Stock Bajo</div>
                        <div class="fs-4 fw-bold">@Model.LowStockProducts</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Today's Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-6 col-lg-4">
        <div class="admin-card">
            <div class="admin-card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-primary bg-opacity-10 text-primary rounded p-3">
                            <i class="bi bi-calendar-check fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <div class="text-muted small">Órdenes Hoy</div>
                        <div class="fs-4 fw-bold">@Model.TodayOrders</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="admin-card">
            <div class="admin-card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-success bg-opacity-10 text-success rounded p-3">
                            <i class="bi bi-cash-stack fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <div class="text-muted small">Ingresos Hoy</div>
                        <div class="fs-4 fw-bold">${Model.TodayRevenue:N2}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="admin-card">
            <div class="admin-card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-danger bg-opacity-10 text-danger rounded p-3">
                            <i class="bi bi-hourglass-split fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <div class="text-muted small">Órdenes Pendientes</div>
                        <div class="fs-4 fw-bold">@Model.PendingOrders</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2>Acciones Rápidas</h2>
            </div>
            <div class="admin-card-body">
                <div class="row g-3">
                    <div class="col-sm-6 col-md-4">
                        <a asp-page="/Products/Create" class="btn btn-outline-primary w-100 py-3">
                            <i class="bi bi-plus-circle fs-4 d-block mb-2"></i>
                            Agregar Producto
                        </a>
                    </div>
                    
                    @if (Model.IsAdmin)
                    {
                        <div class="col-sm-6 col-md-4">
                            <a asp-page="/Categories/Create" class="btn btn-outline-primary w-100 py-3">
                                <i class="bi bi-tags fs-4 d-block mb-2"></i>
                                Nueva Categoría
                            </a>
                        </div>
                    }
                    
                    <div class="col-sm-6 col-md-4">
                        <a asp-page="/Orders/Index" class="btn btn-outline-primary w-100 py-3">
                            <i class="bi bi-cart fs-4 d-block mb-2"></i>
                            Ver Pedidos
                        </a>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <a asp-page="/Products/Index" class="btn btn-outline-primary w-100 py-3">
                            <i class="bi bi-box-seam fs-4 d-block mb-2"></i>
                            Gestionar Productos
                        </a>
                    </div>
                    
                    @if (Model.IsAdmin)
                    {
                        <div class="col-sm-6 col-md-4">
                            <a asp-page="/Users/Index" class="btn btn-outline-primary w-100 py-3">
                                <i class="bi bi-people fs-4 d-block mb-2"></i>
                                Ver Usuarios
                            </a>
                        </div>
                        <div class="col-sm-6 col-md-4">
                            <a asp-page="/Reports/Index" class="btn btn-outline-primary w-100 py-3">
                                <i class="bi bi-graph-up fs-4 d-block mb-2"></i>
                                Reportes
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2>Resumen</h2>
            </div>
            <div class="admin-card-body">
                @if (Model.IsAdmin)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Categorías</span>
                            <strong>@Model.TotalCategories</strong>
                        </div>
                        <hr class="my-2">
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Usuarios</span>
                            <strong>@Model.TotalUsers</strong>
                        </div>
                        <hr class="my-2">
                    </div>
                }
                <div>
                    <a asp-page="/Products/Index" asp-route-sortOrder="stock" class="btn btn-warning w-100">
                        <i class="bi bi-exclamation-circle"></i> Ver Productos con Stock Bajo
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
