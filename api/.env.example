NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=postgres

# JWT — change to a long random secret in production
JWT_SECRET=change_me_to_a_long_random_secret
